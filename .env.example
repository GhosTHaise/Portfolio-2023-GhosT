# Server-only Brevo credentials. Never prefix these with NEXT_PUBLIC_.
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=Portfolio contact form

# Optional. Defaults to ghostrex2@gmail.com.
CONTACT_RECEIVER_EMAIL=ghostrex2@gmail.com

# Existing Sanity configuration used to store contact submissions.
REACT_APP_SANITY_PROJECT_ID=your_sanity_project_id
SANITY_TOKEN=your_sanity_write_token
